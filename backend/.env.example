DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/activia_trace
DATABASE_URL_TEST=postgresql+asyncpg://user:password@localhost:5432/activia_trace_test

SECRET_KEY=your-secret-key-min-32-chars-here
# ENCRYPTION_KEY must be exactly 32 bytes (UTF-8).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=01234567890123456789012345678901

ACCESS_TOKEN_EXPIRE_MINUTES=15

OTEL_SERVICE_NAME=activia-trace
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SDK_ENABLED=true